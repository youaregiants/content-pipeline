# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit your actual keys.

# Anthropic (claude.ai/api)
ANTHROPIC_API_KEY=sk-ant-...

# Ayrshare Business plan (app.ayrshare.com → Profile → API Key)
AYRSHARE_API_KEY=...

# Optional overrides
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
